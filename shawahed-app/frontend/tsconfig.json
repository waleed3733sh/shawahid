{
  "compilerOptions": {
    "target": "ES2021", "lib": ["dom", "esnext"], "jsx": "preserve",
    "module": "esnext", "moduleResolution": "bundler", "esModuleInterop": true,
    "strict": true, "skipLibCheck": true, "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] }, "plugins": [{ "name": "next" }]
  },
  "include": ["src", "next-env.d.ts"]
}
